{
  "name": "@aimani-gs/oauth-callback-spike",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:migrate:local": "wrangler d1 execute oauth-callback-spike-db --local --file=./migrations/0001_better_auth.sql",
    "db:migrate:remote": "wrangler d1 execute oauth-callback-spike-db --remote --file=./migrations/0001_better_auth.sql"
  },
  "dependencies": {
    "better-auth": "^1.6.20",
    "hono": "^4.12.0",
    "kysely": "^0.29.2",
    "kysely-d1": "^0.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250620.0",
    "typescript": "^5.8.0",
    "wrangler": "^4.0.0"
  }
}
